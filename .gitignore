# User data uploads (just in case)
uploads/
*.user.xlsx
*.user.xlsm
*.user.csv

# Persistent input store — populated at runtime with actual user data,
# never committed. The folder is auto-created on first upload.
input/

# Per-session error log files written by the app. Auto-created.
log/

# NOTE: `sample_data/` is intentionally NOT gitignored. The files there are
# fully synthetic (generated by sample_data/generate_samples.py) and exist so
# anyone cloning the repo can run the dashboard end-to-end without supplying
# their own data. They contain no real project information.
